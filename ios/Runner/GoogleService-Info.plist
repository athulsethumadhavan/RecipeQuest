<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  REPLACE THIS FILE with the real GoogleService-Info.plist downloaded from:
  Firebase Console → Project Settings → Your Apps → iOS app → Download GoogleService-Info.plist

  Make sure the BUNDLE_ID below matches your Xcode project:
  com.athul.recipequest
-->
<plist version="1.0">
<dict>
    <key>_README</key>
    <string>Replace this file with the real GoogleService-Info.plist from Firebase Console</string>
    <key>CLIENT_ID</key>
    <string>YOUR_CLIENT_ID.apps.googleusercontent.com</string>
    <key>REVERSED_CLIENT_ID</key>
    <string>com.googleusercontent.apps.YOUR_CLIENT_ID</string>
    <key>API_KEY</key>
    <string>YOUR_IOS_API_KEY</string>
    <key>GCM_SENDER_ID</key>
    <string>YOUR_PROJECT_NUMBER</string>
    <key>PLIST_VERSION</key>
    <string>1</string>
    <key>BUNDLE_ID</key>
    <string>com.athul.recipequest</string>
    <key>PROJECT_ID</key>
    <string>YOUR_PROJECT_ID</string>
    <key>STORAGE_BUCKET</key>
    <string>YOUR_PROJECT_ID.appspot.com</string>
    <key>IS_ADS_ENABLED</key>
    <false/>
    <key>IS_ANALYTICS_ENABLED</key>
    <false/>
    <key>IS_APPINVITE_ENABLED</key>
    <true/>
    <key>IS_GCM_ENABLED</key>
    <true/>
    <key>IS_SIGNIN_ENABLED</key>
    <true/>
    <key>GOOGLE_APP_ID</key>
    <string>1:YOUR_PROJECT_NUMBER:ios:XXXXXXXXXXXXXXXX</string>
</dict>
</plist>
