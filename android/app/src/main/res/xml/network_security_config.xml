<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows cleartext only for AdMob test server during development.
  All production traffic (Firebase, YouTube, your API) already uses HTTPS.
  Remove the debug-overrides block before submitting to Play Store.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow AdMob test ads on emulator during development -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
